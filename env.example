FLASK_APP=run.py
FLASK_ENV=development

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=your-strong-password-here
DATABASE_URL=postgresql://kvitkova_user:your-strong-password-here@postgres:5432/kvitkova_crm

# Security
SECRET_KEY=your-secret-key-here

# Admin user (створюється через flask ensure-admin)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@kvitkovapovnya.com
ADMIN_PASSWORD=your-admin-password-here

# Telegram bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Route optimizer
ROUTE_OPTIMIZER_URL=http://your-optimizer-host:3000
OPTIMIZER_API_KEY=
DEPOT_ADDRESS=вулиця Хрещатик, 1, Київ

# AI Agent (OpenAI-compatible API)
AI_API_KEY=your-ai-api-key-here
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_MODEL=gemini-2.5-flash

# Redis
REDIS_URL=redis://redis:6379/0
